#!/bin/zsh
# ivy — strict venv wrapper so all Ivy commands use .venv/bin/python, never
# the system Python 3.9 that ships with macOS (which causes LibreSSL warnings
# and may lack required packages).
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"
PYTHON="$PROJECT_ROOT/.venv/bin/python"
CLI="$PROJECT_ROOT/ivy_cli.py"

if [[ ! -x "$PYTHON" ]]; then
    echo "ERROR: Ivy virtual environment not found: $PYTHON" >&2
    echo "Run: python3 -m venv .venv && .venv/bin/pip install -r requirements.txt" >&2
    exit 1
fi

if [[ ! -f "$CLI" ]]; then
    echo "ERROR: Ivy CLI not found: $CLI" >&2
    exit 1
fi

cd "$PROJECT_ROOT"
exec "$PYTHON" "$CLI" "$@"
