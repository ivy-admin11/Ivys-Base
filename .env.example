# Google APIs
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_SERVICE_ACCOUNT_KEY=path/to/service-account-key.json

# DeepSeek (primary LLM)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# xAI (Grok) — used by the 'brain' job
XAI_API_KEY=your_xai_api_key_here

# External Services
ODDS_API_KEY=your_odds_api_key_here
READWISE_API_KEY=your_readwise_api_key_here

# Contacts
HENRY_PHONE=+10000000000
LEXI_PHONE=+10000000000

# Security — required; the process refuses to start without this set.
# For local/test use only, set ALLOW_INSECURE_ADMIN_SECRET=true instead.
ADMIN_SECRET=your_shared_secret_here

# Feature flags
ENABLE_IMESSAGE_POLLER=true
ENABLE_CALENDAR_INTEGRATION=true
ENABLE_REMINDERS_INTEGRATION=true
ENABLE_READWISE_INTEGRATION=true
ENABLE_SPORTS_PICKS=true
ENABLE_GROCERY_STAGING=true

# Local Configuration
UVICORN_HOST=127.0.0.1
UVICORN_PORT=8000
