# ============================================================================
# Ivy Local Admin API Gateway — Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file itself to version control.
# Store sensitive values securely (1Password, LastPass, AWS Secrets Manager, etc.)
#
# ⚠️  SECURITY: This file will contain API keys and credentials. Keep it:
#     - Out of version control (.gitignore)
#     - With restricted file permissions (chmod 600)
#     - Only on trusted machines
# ============================================================================

# --- Core Gateway Configuration ---
ADMIN_SECRET=your_shared_secret_key_here_change_this_in_production
CHAT_DB_PATH=/Users/lexi/Library/Messages/chat.db
POLLING_INTERVAL=1

# --- Primary LLM: Google Gemini ---
# Get from: https://makersuite.google.com/app/apikeys
GEMINI_API_KEY=your_gemini_api_key_here

# --- Failover LLM: DeepSeek ---
# Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# --- Readwise Integration (Optional) ---
# Get from: https://readwise.io/access_token
READWISE_API_KEY=your_readwise_api_key_here

# --- Grocery Store Automation: H-E-B ---
# Your H-E-B account credentials (for Playwright browser automation)
HEB_USERNAME=your_heb_email@example.com
HEB_PASSWORD=your_heb_password_here

# --- Grocery Store Automation: Kroger ---
# Your Kroger account credentials (for Playwright browser automation)
KROGER_USERNAME=your_kroger_email@example.com
KROGER_PASSWORD=your_kroger_password_here

# --- iMessage Recipients (Authorized Phone Numbers) ---
# Primary authorized contact (Henry Hilla) — used for approval workflows
HENRY_PHONE=+12147334061

# --- Google Cloud Platform (GCP Service Account) ---
# Path to your GCP service account JSON key file
# Generate from: https://console.cloud.google.com/iam-admin/serviceaccounts
GCP_SERVICE_ACCOUNT_KEY_PATH=/Users/lexi/openclaw-admin/service-account-key.json
GCP_PROJECT_ID=ai-gateway-v2-494905

# --- Google Docs & Slides API (Optional, if using document automation) ---
# These are typically obtained via OAuth 2.0 flow; store the refresh token here
GOOGLE_OAUTH_REFRESH_TOKEN=your_google_oauth_refresh_token_here
GOOGLE_DOCS_FOLDER_ID=your_google_drive_folder_id_for_docs

# --- Logging & Debugging ---
LOG_LEVEL=INFO
# Options: DEBUG (verbose), INFO (standard), WARNING (errors only), CRITICAL (system failures)

# --- Playwright Browser Engine ---
# If True, /stage_groceries endpoint is enabled. Set False to disable browser automation.
PLAYWRIGHT_ENABLED=true
PLAYWRIGHT_HEADLESS=true

# --- MCP (Model Context Protocol) Servers (Optional) ---
# If using external MCP tool servers, define their startup parameters
MCP_SERVER_COMMAND=/path/to/mcp/server/executable
MCP_SERVER_ARGS=--arg1 value1 --arg2 value2
MCP_SERVER_CWD=/path/to/mcp/server/working/directory

# --- Database & Storage ---
# SQLite database for caching and state management (if needed)
STATE_DB_PATH=/Users/lexi/openclaw-admin/state.db

# --- Feature Flags ---
# Enable/disable specific integrations without code changes
ENABLE_IMESSAGE_POLLER=true
ENABLE_GROCERY_STAGING=true
ENABLE_CALENDAR_INTEGRATION=true
ENABLE_REMINDERS_INTEGRATION=true
ENABLE_READWISE_INTEGRATION=true

# --- API Rate Limiting & Timeouts (Optional) ---
# Maximum requests per minute from a single source
API_RATE_LIMIT=100

# Request timeout for external API calls (seconds)
EXTERNAL_API_TIMEOUT=20

# SQLite database timeout (seconds)
DB_TIMEOUT=5

# ============================================================================
# NOTES:
# ============================================================================
# 1. All credential values are EXAMPLES only. Replace with your actual credentials.
# 2. For sensitive values, consider using a secrets manager instead of .env files.
# 3. The gateway reads this file on startup via the native environment loader.
# 4. If a variable is missing, the system will log a warning and disable that feature.
# 5. Always use HTTPS and proper authentication (ADMIN_SECRET header) in production.
# 6. For GitHub Actions or CI/CD, use repository secrets instead of .env files.
# ============================================================================
